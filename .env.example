# ── Plivo (Test B only) ────────────────────────────────────────────────
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=          # Plivo caller-ID number, E.164 (India number needs KYC)
TEST_TO_NUMBER=            # your verified mobile, E.164 (+91...)

# Public host that ngrok gives you (host only, NO https://, NO trailing slash)
# e.g. abc123.ngrok-free.app
NGROK_HOST=

# ── LLM ────────────────────────────────────────────────────────────────
# Provider: "sarvam" (India-hosted Sarvam-30b, ~6x faster TTFB, uses SARVAM_API_KEY)
#           or "openrouter" (fallback).
LLM_PROVIDER=sarvam
SARVAM_LLM_MODEL=sarvam-105b   # sarvam-105b (smartest) | sarvam-30b (faster, more robotic). reasoning auto-disabled in code
# OpenRouter fallback (only used when LLM_PROVIDER=openrouter):
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# ── Sarvam AI (STT + TTS) ──────────────────────────────────────────────
SARVAM_API_KEY=
# STT model: saaras:v3 (default) | saarika:v2.5 | saaras:v2.5
SARVAM_STT_MODEL=saaras:v3
# TTS model: bulbul:v3 (most natural) | bulbul:v2 (supports pitch/loudness)
SARVAM_TTS_MODEL=bulbul:v3
# v3 female voices: priya ritu neha pooja simran kavya ishita shreya | v2: anushka manisha vidya
SARVAM_TTS_VOICE=priya
SARVAM_TTS_PACE=0.95            # <1.0 = warmer/friendlier
SARVAM_TTS_TEMP=0.5            # v3 only: expressiveness 0.4-0.6
# BCP-47 India code: en-IN hi-IN bn-IN gu-IN kn-IN ml-IN mr-IN pa-IN ta-IN te-IN
SARVAM_LANGUAGE=en-IN

# ── Audio ──────────────────────────────────────────────────────────────
# Pipeline sample rate for the LOCAL mic test (Test A). Sarvam STT accepts
# 8000 or 16000. The Plivo phone leg (Test B) is forced to 8000 in code.
LOCAL_SAMPLE_RATE=16000

# ── Latency tuning (lower = snappier, but more cut-off risk) ──
SARVAM_TTFS_P99=0.5          # STT turn-stop wait. 1.17 default => ~0.97s dead air/turn; 0.5 => ~0.3s
LLM_MAX_TOKENS=150           # reply length cap (Sarvam reasoning disabled, so content-only)
LLM_TEMPERATURE=0.6          # higher = more varied/natural (low temp caused verbatim repetition)
SMART_TURN_STOP_SECS=1.5     # Smart Turn wait when caller seems unfinished (3.0 default; lower=snappier, more cut-off risk)
IDLE_TIMEOUT_SECS=7          # caller-silence auto-hangup: nudge ~7s, hang up ~14s
# NOTE: do NOT set Sarvam TTS min_buffer_size below ~50 — its WS server rejects it.
